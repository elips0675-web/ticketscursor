PORT=4000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=servicedesk
# Обязательно: сгенерируйте свой ключ, например: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production
# Разрешённые источники для CORS (через запятую)
CORS_ORIGIN=http://localhost:5173
# Rate limit: auth 10/мин, api 100/мин, admin 30/мин (настраивается тут)
# RATE_LIMIT_API=100
# RATE_LIMIT_AUTH=10
# Сгенерируйте свои: node -e "const wp = require('web-push'); const k = wp.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY='+k.publicKey); console.log('VAPID_PRIVATE_KEY='+k.privateKey);"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@servicedesk.local

# Email (SMTP) — опционально
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-password
# SMTP_FROM=Service Desk <noreply@servicedesk.local>

# Refresh token secret (по умолчанию JWT_SECRET + '-refresh')
# REFRESH_SECRET=your-refresh-secret

# Sentry — опционально
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_SAMPLE_RATE=0.1

# S3 / MinIO — опционально (если не задано — локальное хранение)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=servicedesk
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# ClamAV — опционально
# CLAMAV_ENABLED=true

# Telegram — опционально
# TELEGRAM_BOT_TOKEN=your-bot-token-from-@BotFather
